<style>
  .pixel-grid {
    background-size: 40px 40px;
    background-image: radial-gradient(circle, #dcdddd 1px, transparent 1px);
  }
  .back-out-transition {
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>

<div class="min-h-screen pixel-grid flex flex-col items-center justify-center p-6 relative overflow-x-hidden bg-surface">

  <!-- Decorative stickers -->
  <div class="absolute top-10 left-10 -rotate-12 bg-secondary-container p-3 sticker-shadow hidden md:block">
    <span class="material-symbols-outlined text-4xl text-on-surface">sports_esports</span>
  </div>
  <div class="absolute bottom-20 right-10 rotate-12 bg-tertiary-container p-3 sticker-shadow hidden md:block">
    <span class="material-symbols-outlined text-4xl text-on-surface" style="font-variation-settings: 'FILL' 1;">favorite</span>
  </div>
  <div class="absolute top-1/4 right-20 rotate-6 bg-primary-container p-2 sticker-shadow hidden lg:block">
    <span class="material-symbols-outlined text-3xl text-on-surface">videogame_asset</span>
  </div>
  <div class="absolute bottom-1/4 left-20 -rotate-3 bg-surface-container p-2 sticker-shadow hidden lg:block">
    <span class="material-symbols-outlined text-3xl text-on-surface" style="font-variation-settings: 'FILL' 1;">star</span>
  </div>

  <!-- Branding -->
  <div class="mb-8 text-center">
    <h1 class="font-headline font-black italic text-8xl tracking-tighter text-primary uppercase drop-shadow-[4px_4px_0px_rgba(45,47,47,1)] select-none">
      Herd
    </h1>
    <p class="font-headline text-sm font-bold tracking-widest text-secondary mt-2 uppercase">Level up your squad</p>
  </div>

  <!-- Sign Up Card -->
  <div class="w-full max-w-md bg-surface-container-lowest border-4 border-on-surface sticker-shadow p-8 relative z-10">

    <div class="mb-8 border-b-4 border-surface-container pb-4">
      <h2 class="font-headline text-3xl font-extrabold tracking-tight text-on-surface">Start Your Journey</h2>
      <p class="text-on-surface-variant font-medium text-sm mt-1">Create your profile to join the lobby.</p>
    </div>

    <!-- Error messages -->
    <% if @user.errors.any? %>
      <div class="mb-6 p-4 border-4 border-primary bg-primary/10">
        <% @user.errors.full_messages.each do |message| %>
          <p class="text-primary font-bold text-sm uppercase"><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @user, url: registrations_path, class: "space-y-6" do |f| %>

      <!-- Username -->
      <div>
        <%= f.label :username, "Gamer Tag", class: "block text-xs font-bold uppercase tracking-wider text-secondary mb-2" %>
        <%= f.text_field :username,
            placeholder: "P1_MASTER",
            class: "w-full bg-surface-container border-2 border-on-surface p-4 font-headline font-bold text-on-surface focus:outline-none focus:border-primary back-out-transition placeholder:text-outline placeholder:font-normal" %>
      </div>

      <!-- Email -->
      <div>
        <%= f.label :email_address, "Comm Channel (Email)", class: "block text-xs font-bold uppercase tracking-wider text-secondary mb-2" %>
        <%= f.email_field :email_address,
            placeholder: "SQUAD@HERD.GG",
            class: "w-full bg-surface-container border-2 border-on-surface p-4 font-headline font-bold text-on-surface focus:outline-none focus:border-primary back-out-transition placeholder:text-outline placeholder:font-normal" %>
      </div>

      <!-- Password -->
      <div>
        <%= f.label :password, "Access Code", class: "block text-xs font-bold uppercase tracking-wider text-secondary mb-2" %>
        <%= f.password_field :password,
            placeholder: "••••••••",
            class: "w-full bg-surface-container border-2 border-on-surface p-4 font-headline font-bold text-on-surface focus:outline-none focus:border-primary back-out-transition" %>
      </div>

      <!-- Password Confirmation -->
      <div>
        <%= f.label :password_confirmation, "Verify Code", class: "block text-xs font-bold uppercase tracking-wider text-secondary mb-2" %>
        <%= f.password_field :password_confirmation,
            placeholder: "••••••••",
            class: "w-full bg-surface-container border-2 border-on-surface p-4 font-headline font-bold text-on-surface focus:outline-none focus:border-primary back-out-transition" %>
      </div>

      <!-- Submit -->
      <%= f.submit "Create Account",
          class: "w-full bg-tertiary text-on-tertiary font-headline text-xl font-black uppercase tracking-tighter p-5 border-4 border-on-surface sticker-shadow sticker-shadow-hover back-out-transition cursor-pointer active:translate-y-0 active:shadow-none" %>

    <% end %>

    <div class="mt-8 pt-6 border-t-4 border-surface-container text-center">
      <p class="text-sm font-bold text-on-surface-variant uppercase tracking-wide">
        Already have an account?
        <%= link_to "Log In", new_session_path, class: "text-primary ml-1 back-out-transition p-1 hover:bg-primary-container" %>
      </p>
    </div>

  </div>

  <!-- Footer -->
  <footer class="mt-12 text-center text-outline text-xs font-bold uppercase tracking-widest relative z-10">
    &copy; <%= Time.current.year %> HERD ARCADE // LEVEL UP YOUR SQUAD
  </footer>

</div>
