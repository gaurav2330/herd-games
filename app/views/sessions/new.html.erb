<style>
  .pixel-grid {
    background-image: radial-gradient(circle, #e2e3e3 1.5px, transparent 1.5px);
    background-size: 24px 24px;
  }
  .cubic-bezier-bouncy {
    transition-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
  }
</style>

<div class="min-h-screen flex flex-col items-center justify-center pixel-grid px-6 py-12 bg-surface font-body text-on-surface">

  <!-- Decorative floating elements -->
  <div class="fixed top-20 left-[10%] hidden xl:block animate-bounce" style="animation-duration: 3s">
    <div class="w-12 h-12 bg-secondary-container border-4 border-on-surface transform rotate-12 flex items-center justify-center sticker-shadow">
      <span class="material-symbols-outlined text-on-surface" style="font-variation-settings: 'FILL' 1;">star</span>
    </div>
  </div>
  <div class="fixed bottom-20 right-[10%] hidden xl:block animate-bounce" style="animation-duration: 4s">
    <div class="w-16 h-16 bg-tertiary-container border-4 border-on-surface transform -rotate-12 flex items-center justify-center sticker-shadow">
      <span class="material-symbols-outlined text-on-tertiary-container text-3xl" style="font-variation-settings: 'FILL' 1;">diamond</span>
    </div>
  </div>

  <!-- Branding -->
  <div class="mb-12 flex flex-col items-center">
    <div class="relative">
      <div class="absolute -top-2 -right-2 w-full h-full bg-secondary-fixed opacity-20 -z-10 transform skew-x-12"></div>
      <h1 class="font-headline text-7xl md:text-9xl font-black italic uppercase tracking-tighter text-primary leading-none select-none">
        HERD
      </h1>
    </div>
    <p class="font-headline text-lg mt-4 text-on-surface-variant font-medium tracking-widest uppercase">
      Ready Player One
    </p>
  </div>

  <!-- Login Card -->
  <main class="w-full max-w-md">
    <div class="bg-surface-container-lowest border-4 border-on-surface p-8 md:p-10 shadow-[8px_8px_0px_0px_rgba(45,47,47,1)] relative">

      <!-- Sticker tag -->
      <div class="absolute -top-6 -left-4 bg-tertiary text-on-tertiary px-4 py-1 font-headline font-bold text-sm uppercase tracking-wider transform -rotate-3 border-2 border-on-surface">
        Level Up
      </div>

      <!-- Flash alert -->
      <% if alert %>
        <div class="mb-6 p-4 border-4 border-primary bg-primary/10">
          <p class="text-primary font-bold text-sm uppercase"><%= alert %></p>
        </div>
      <% end %>

      <%= form_with url: session_path, class: "space-y-6" do |f| %>

        <!-- Email -->
        <div class="space-y-2">
          <%= f.label :email_address, "Username or Email", class: "block font-headline text-sm font-extrabold uppercase tracking-tight text-on-surface" %>
          <div class="relative">
            <%= f.email_field :email_address,
                placeholder: "ARCADE_MASTER",
                autocomplete: "email",
                class: "w-full h-14 px-4 bg-surface-container border-2 border-on-surface font-body text-on-surface focus:ring-0 focus:border-primary focus:border-4 cubic-bezier-bouncy transition-all placeholder:text-outline-variant outline-none" %>
            <span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline">person</span>
          </div>
        </div>

        <!-- Password -->
        <div class="space-y-2">
          <div class="flex justify-between items-center">
            <%= f.label :password, "Secret Key", class: "block font-headline text-sm font-extrabold uppercase tracking-tight text-on-surface" %>
            <%= link_to "Forgot Password?", new_password_path, class: "text-xs font-bold text-tertiary hover:underline uppercase tracking-tighter" %>
          </div>
          <div class="relative">
            <%= f.password_field :password,
                placeholder: "••••••••",
                autocomplete: "current-password",
                class: "w-full h-14 px-4 bg-surface-container border-2 border-on-surface font-body text-on-surface focus:ring-0 focus:border-primary focus:border-4 cubic-bezier-bouncy transition-all placeholder:text-outline-variant outline-none" %>
            <span class="absolute right-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline">lock</span>
          </div>
        </div>

        <!-- Submit Button -->
        <button type="submit" class="group relative w-full h-16 mt-4 cubic-bezier-bouncy transition-all active:translate-y-1 active:translate-x-1">
          <div class="absolute inset-0 bg-on-primary-container translate-x-1.5 translate-y-1.5 border-2 border-on-surface"></div>
          <div class="absolute inset-0 bg-primary border-2 border-on-surface flex items-center justify-center group-hover:-translate-x-1 group-hover:-translate-y-1 transition-transform cubic-bezier-bouncy">
            <span class="font-headline text-xl font-black text-on-primary uppercase tracking-wider">Log In</span>
            <span class="material-symbols-outlined ml-2 text-on-primary" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
          </div>
        </button>

      <% end %>

      <!-- Divider -->
      <div class="my-10 flex items-center">
        <div class="flex-grow h-[2px] bg-surface-container-high"></div>
        <span class="px-4 font-headline text-xs font-bold text-outline-variant uppercase">Or</span>
        <div class="flex-grow h-[2px] bg-surface-container-high"></div>
      </div>

      <!-- Sign up link -->
      <div class="text-center space-y-4">
        <p class="font-body text-sm text-on-surface-variant font-medium">
          New player?
          <%= link_to "Sign Up Now", new_registration_path, class: "font-headline font-black text-primary uppercase ml-1 border-b-2 border-primary hover:text-primary-dim transition-colors" %>
        </p>
        <div class="flex justify-center space-x-6 opacity-40">
          <span class="material-symbols-outlined text-2xl">sports_esports</span>
          <span class="material-symbols-outlined text-2xl">videogame_asset</span>
          <span class="material-symbols-outlined text-2xl">joystick</span>
        </div>
      </div>

    </div>
  </main>

</div>
