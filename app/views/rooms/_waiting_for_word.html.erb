<div class="flex-1 flex flex-col items-center justify-center gap-8">
  <div class="relative">
    <div class="w-32 h-32 border-4 border-on-surface bg-secondary-container flex items-center justify-center">
      <span class="material-symbols-outlined text-6xl animate-pulse" style="font-variation-settings: 'FILL' 1;">brush</span>
    </div>
    <div class="absolute -top-3 -right-3 bg-primary text-on-primary border-4 border-on-surface px-3 py-1 font-headline font-black text-xs uppercase rotate-3">
      Selecting...
    </div>
  </div>

  <div class="text-center">
    <h2 class="font-headline font-black text-4xl uppercase text-on-surface">
      <%= turn.user.username %> is choosing a word
    </h2>
    <p class="text-on-surface-variant font-bold mt-3 uppercase tracking-widest text-sm">Get ready to guess!</p>
  </div>

  <div class="flex gap-3">
    <div class="w-4 h-4 bg-primary border-2 border-on-surface animate-bounce" style="animation-delay: 0ms"></div>
    <div class="w-4 h-4 bg-secondary border-2 border-on-surface animate-bounce" style="animation-delay: 150ms"></div>
    <div class="w-4 h-4 bg-tertiary border-2 border-on-surface animate-bounce" style="animation-delay: 300ms"></div>
  </div>
</div>