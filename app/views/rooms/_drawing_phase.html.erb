<div data-controller="canvas"
     data-canvas-drawer-id-value="<%= turn.user_id %>"
     data-canvas-room-id-value="<%= room.id %>"
     data-canvas-turn-id-value="<%= turn.id %>"
     class="flex-1 flex flex-col gap-4 overflow-hidden">

  <!-- Canvas -->
  <div class="flex-1 bg-on-surface p-3 border-4 border-on-surface shadow-[8px_8px_0px_0px_rgba(45,47,47,0.2)] flex flex-col">
    <div class="flex-1 bg-white relative overflow-hidden">
      <canvas id="game-canvas"
        data-canvas-target="canvas"
        class="absolute inset-0 w-full h-full cursor-default">
      </canvas>
    </div>

    <!-- Drawing toolbar — hidden by default, shown to drawer by Stimulus -->
    <div data-canvas-target="toolbar" class="hidden mt-3 flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-2">

        <!-- Tools -->
        <button data-action="click->canvas#setPencil"
          class="w-12 h-12 bg-secondary-container border-2 border-on-surface flex items-center justify-center active:translate-x-1 active:translate-y-1 transition-all">
          <span class="material-symbols-outlined">edit</span>
        </button>
        <button data-action="click->canvas#setEraser"
          class="w-12 h-12 bg-surface border-2 border-on-surface flex items-center justify-center active:translate-x-1 active:translate-y-1 transition-all">
          <span class="material-symbols-outlined">ink_eraser</span>
        </button>

        <div class="h-8 w-px bg-on-surface-variant mx-2"></div>

        <!-- Color palette -->
        <div class="grid grid-cols-5 gap-1">
          <% [
            "#000000", "#b41b00", "#0545ef", "#6e5900", "#16a34a",
            "#ffffff", "#f97316", "#7c3aed", "#ec4899", "#06b6d4"
          ].each do |color| %>
            <div class="w-6 h-6 border-2 border-on-surface cursor-pointer hover:scale-125 transition-transform"
              style="background-color: <%= color %>;"
              data-action="click->canvas#setColor"
              data-color="<%= color %>">
            </div>
          <% end %>
        </div>

      </div>

      <div class="flex items-center gap-4">

        <!-- Brush sizes -->
        <div class="flex items-center gap-2">
          <% [[4, 20], [8, 24], [14, 30]].each do |size, box| %>
            <div class="border-2 border-on-surface cursor-pointer flex items-center justify-center bg-surface hover:bg-secondary-container transition-colors active:translate-x-1 active:translate-y-1"
              style="width: <%= box %>px; height: <%= box %>px;"
              data-action="click->canvas#setSize"
              data-size="<%= size %>">
              <div class="rounded-full bg-on-surface" style="width: <%= size %>px; height: <%= size %>px;"></div>
            </div>
          <% end %>
        </div>

        <button data-action="click->canvas#clear"
          class="px-6 py-2 bg-error text-on-error font-headline font-bold border-2 border-on-surface active:translate-x-1 active:translate-y-1 uppercase transition-all">
          Clear
        </button>

      </div>
    </div>
  </div>

</div>
