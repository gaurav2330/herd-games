<!-- Word hint bar -->
<div class="bg-surface border-4 border-on-surface p-4 flex items-center justify-center shadow-[4px_4px_0px_0px_#2d2f2f]">
  <% if is_drawer %>
    <div class="flex flex-col items-center">
      <span class="text-xs font-bold uppercase text-on-surface-variant tracking-widest mb-1">Your word — don't say it!</span>
      <span class="font-headline font-black text-3xl tracking-widest uppercase text-primary">
        <%= turn.word %>
      </span>
    </div>
  <% else %>
    <div class="flex flex-col items-center">
      <span class="text-xs font-bold uppercase text-on-surface-variant tracking-widest mb-1">
        <%= turn.user.username %> is drawing...
      </span>
      <span class="font-headline font-black text-3xl tracking-[0.5rem] text-on-surface">
        <%= turn.word&.gsub(/[a-zA-Z]/, "_ ")&.strip %>
      </span>
      <span class="text-xs font-bold text-on-surface-variant mt-1"><%= turn.word&.length %> letters</span>
    </div>
  <% end %>
</div>

<!-- Canvas area -->
<div class="flex-1 bg-on-surface p-3 border-4 border-on-surface shadow-[8px_8px_0px_0px_rgba(45,47,47,0.2)] flex flex-col">
  <div class="flex-1 bg-white relative overflow-hidden">
    <canvas id="game-canvas"
      class="absolute inset-0 w-full h-full <%= is_drawer ? 'cursor-crosshair' : 'cursor-default pointer-events-none' %>"
      data-controller="canvas"
      data-canvas-is-drawer-value="<%= is_drawer %>"
      data-canvas-room-id-value="<%= turn.round.room_id %>"
      data-canvas-turn-id-value="<%= turn.id %>">
    </canvas>
  </div>

  <% if is_drawer %>
    <!-- Drawing toolbar -->
    <div class="mt-3 flex items-center justify-between gap-4 flex-wrap">
      <div class="flex items-center gap-2">
        <!-- Tools -->
        <button id="tool-pencil" class="w-12 h-12 bg-secondary-container border-2 border-on-surface flex items-center justify-center active:translate-x-1 active:translate-y-1 transition-all">
          <span class="material-symbols-outlined">edit</span>
        </button>
        <button id="tool-fill" class="w-12 h-12 bg-surface border-2 border-on-surface flex items-center justify-center active:translate-x-1 active:translate-y-1 transition-all">
          <span class="material-symbols-outlined">format_color_fill</span>
        </button>
        <button id="tool-eraser" class="w-12 h-12 bg-surface border-2 border-on-surface flex items-center justify-center active:translate-x-1 active:translate-y-1 transition-all">
          <span class="material-symbols-outlined">ink_eraser</span>
        </button>

        <div class="h-8 w-px bg-on-surface-variant mx-2"></div>

        <!-- Color palette -->
        <div class="grid grid-cols-5 gap-1" id="color-palette">
          <% [
            "#000000", "#b41b00", "#0545ef", "#6e5900", "#16a34a",
            "#ffffff", "#f97316", "#7c3aed", "#ec4899", "#06b6d4"
          ].each do |color| %>
            <div class="w-6 h-6 border-2 border-on-surface cursor-pointer hover:scale-125 transition-transform"
              style="background-color: <%= color %>;"
              data-color="<%= color %>">
            </div>
          <% end %>
        </div>
      </div>

      <div class="flex items-center gap-4">
        <!-- Brush sizes -->
        <div class="flex items-center gap-2">
          <% [[4, 20], [8, 24], [14, 30]].each do |size, box| %>
            <div class="border-2 border-on-surface cursor-pointer flex items-center justify-center bg-surface hover:bg-secondary-container transition-colors active:translate-x-1 active:translate-y-1"
              style="width: <%= box %>px; height: <%= box %>px;"
              data-size="<%= size %>">
              <div class="rounded-full bg-on-surface" style="width: <%= size %>px; height: <%= size %>px;"></div>
            </div>
          <% end %>
        </div>

        <button id="clear-canvas"
          class="px-6 py-2 bg-error text-on-error font-headline font-bold border-2 border-on-surface active:translate-x-1 active:translate-y-1 uppercase transition-all">
          Clear
        </button>
      </div>
    </div>
  <% end %>
</div>
